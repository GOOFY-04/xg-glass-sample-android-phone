# ----------------------------
# Universal Glasses SDK (Android) - .gitignore
# Covers: Gradle/Android Studio + Flutter module under ./frame_module
# ----------------------------

# IDE
.idea/
*.iml
*.ipr
*.iws
.DS_Store

# Gradle / Android build outputs
.gradle/
.kotlin/
**/build/
**/out/
captures/

# Local config (machine-specific)
local.properties
**/local.properties
*.keystore
*.jks

# Android Studio / IntelliJ
.externalNativeBuild/
.cxx/

# Logs
*.log

# ----------------------------
# Flutter module (./third_party/frame/frame_module)
# ----------------------------

# Flutter tool caches / build outputs
third_party/frame/frame_module/.dart_tool/
third_party/frame/frame_module/build/
third_party/frame/frame_module/.flutter-plugins
third_party/frame/frame_module/.flutter-plugins-dependencies
third_party/frame/frame_module/.metadata

# Generated platform scaffolding (re-create with `flutter create -t module ...`)
third_party/frame/frame_module/.android/
third_party/frame/frame_module/.ios/

# Optional: lockfile (commit if you want reproducible app-like builds; ignore to reduce churn)
third_party/frame/frame_module/pubspec.lock

