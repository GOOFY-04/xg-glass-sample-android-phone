# ----------------------------
# Universal Glasses SDK (Android) - .gitignore
# Covers: Gradle/Android Studio + Flutter module under ./frame_module
# ----------------------------

# IDE
.idea/
*.iml
*.ipr
*.iws
.DS_Store

# Gradle / Android build outputs
.gradle/
.kotlin/
**/build/
**/out/
captures/

# Local config (machine-specific)
local.properties
**/local.properties
*.keystore
*.jks

# Android Studio / IntelliJ
.externalNativeBuild/
.cxx/

# Logs
*.log

# ----------------------------
# Flutter module (./frame_module)
# ----------------------------

# Flutter tool caches / build outputs
frame_module/.dart_tool/
frame_module/build/
frame_module/.flutter-plugins
frame_module/.flutter-plugins-dependencies
frame_module/.metadata

# Generated platform scaffolding (re-create with `flutter create -t module ...`)
frame_module/.android/
frame_module/.ios/

# Optional: lockfile (commit if you want reproducible app-like builds; ignore to reduce churn)
frame_module/pubspec.lock


